#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std; // guess number game made from scratch

int main()
{
    int num, guess, nguesses = 0;

    srand(time(0));
    num = rand() % 100 + 1; // random number between 1-100

    do
    {
        cout << "Enter your guess: ";
        cin >> guess;
        nguesses++;

        if (guess > num)
        {
            cout << "Lower number please" << endl;
        }
        else if (guess < num)
        {
            cout << "Higher number please" << endl;
        }
        else
        {
            cout << "Bravo! You guessed it right in "
                 << nguesses << " attempts." << endl;
        }

    } while (guess != num);

    return 0;
}
